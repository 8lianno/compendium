<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- File access for reading raw/ sources and writing wiki/ articles -->
	<key>com.apple.security.files.user-selected.read-write</key>
	<true/>

	<!-- Network access for cloud LLM API calls (Anthropic, OpenAI, Gemini) -->
	<key>com.apple.security.network.client</key>
	<true/>

	<!-- Keychain access for secure API key storage -->
	<key>com.apple.security.keychain-access-groups</key>
	<array>
		<string>$(AppIdentifierPrefix)com.compendium.menubar</string>
	</array>
</dict>
</plist>
